// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model UpsellOffer {
  id               String   @id @default(cuid())
  shop             String
  title            String
  description      String
  ctaText          String   @default("Add to Order")
  productId        String
  variantId        String
  productTitle     String
  productImage     String?
  productPrice     String
  discountType     String   // "percentage" | "fixed"
  discountValue    Float
  timeLimitMinutes Int?
  status           String   @default("active") // "draft" | "active" | "paused"
  testMode         Boolean  @default(false)
  priority         Int      @default(0)
  // Scheduling
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fallbackOfferId String?

  abTestId String?
  abTest   ABTest? @relation(fields: [abTestId], references: [id], onDelete: SetNull)

  targetingRules  TargetingRule[]
  analyticsEvents AnalyticsEvent[]

  @@index([shop])
  @@index([shop, status])
}

model TargetingRule {
  id        String      @id @default(cuid())
  offerId   String
  offer     UpsellOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  ruleType  String      // "product" | "collection" | "cart_value" | "quantity" | "order_count" | "customer_tag" | "shipping_country"
  operator  String      // "contains" | "greater_than" | "less_than" | "equals" | "not_equals"
  value     String
  createdAt DateTime    @default(now())
}

model AnalyticsEvent {
  id         String       @id @default(cuid())
  shop       String
  offerId    String?
  offer      UpsellOffer? @relation(fields: [offerId], references: [id], onDelete: Cascade)
  eventType  String       // "view" | "accept" | "decline" | "survey_response" | "social_share"
  orderId    String?
  revenue    Float?
  funnelStep Int         @default(1)
  abTestId   String?
  metadata   String?     // JSON string for extra data (survey answers, share platform, etc.)
  createdAt  DateTime    @default(now())

  @@index([shop])
  @@index([offerId])
  @@index([eventType])
  @@index([createdAt])
}

// A/B Testing
model ABTest {
  id           String    @id @default(cuid())
  shop         String
  name         String
  description  String    @default("")
  status       String    @default("draft") // "draft" | "running" | "completed"
  splitPercent Int       @default(50)
  winnerId     String?
  startedAt    DateTime?
  endedAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  offers UpsellOffer[]
}

// Thank-you page widget configuration per shop
model WidgetConfig {
  id         String  @id @default(cuid())
  shop       String
  widgetType String  // "upsell" | "social_share" | "survey" | "reorder" | "custom_message"
  enabled    Boolean @default(true)
  position   Int     @default(0) // lower = shown first
  settings   String  @default("{}") // JSON — widget-specific settings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, widgetType])
}

// Survey questions configured by merchant
model SurveyQuestion {
  id           String @id @default(cuid())
  shop         String
  question     String
  questionType String @default("rating") // "rating" | "text" | "multiple_choice"
  options      String @default("[]") // JSON array for multiple_choice options
  position     Int    @default(0)
  enabled      Boolean @default(true)
  createdAt    DateTime @default(now())

  responses SurveyResponse[]
}

model SurveyResponse {
  id         String         @id @default(cuid())
  shop       String
  questionId String
  question   SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  orderId    String?
  answer     String
  createdAt  DateTime       @default(now())
}

// Pricing Plans (managed from admin panel)
model Plan {
  id              String   @id @default(cuid())
  name            String   // "Free", "Starter", "Growth", "Pro"
  slug            String   @unique // "free", "starter", "growth", "pro"
  price           Float    @default(0) // monthly USD, 0 = free
  trialDays       Int      @default(3)
  maxOffers       Int      @default(2) // -1 = unlimited
  abTesting       Boolean  @default(false)
  analytics       Boolean  @default(false)
  customBranding  Boolean  @default(false)
  prioritySupport Boolean  @default(false)
  scheduledOffers Boolean  @default(false)
  funnelChaining  Boolean  @default(false)
  csvExport       Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0) // display order
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Subscription / Billing
model Subscription {
  id              String    @id @default(cuid())
  shop            String    @unique
  plan            String    @default("free") // "free" | "starter" | "growth" | "pro"
  status          String    @default("active") // "active" | "cancelled" | "expired" | "pending"
  shopifyChargeId String?   // Shopify's appSubscription GID
  currency        String    @default("USD") // shop's currency code
  trialStartsAt   DateTime?
  trialEndsAt     DateTime?
  currentPeriodEnd DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// Admin panel config
model AdminConfig {
  id           String   @id @default("admin_config")
  password     String   @default("Admin@e07a595") // plain password (for admin to copy/share)
  passwordHash String   // bcrypt hash used for login verification
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Branding settings per shop
model BrandingConfig {
  id              String @id @default(cuid())
  shop            String @unique
  primaryColor    String @default("#000000")
  accentColor     String @default("#22c55e")
  buttonStyle     String @default("rounded") // "rounded" | "square" | "pill"
  showTrustBadges Boolean @default(true)
  customMessage   String @default("") // custom thank-you message
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
